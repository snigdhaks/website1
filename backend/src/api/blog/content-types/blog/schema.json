    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "richtext"
    },
    "excerpt": {
      "type": "text"
    },
    "tags": {
      "type": "json"
    },
    "category": {
      "type": "string"
    },
    "subscribersNotified": {
      "type": "boolean",
      "default": false
    }
  }
