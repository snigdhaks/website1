# Strapi Integration Configuration
# Set VITE_STRAPI_API_URL to connect the website to your Strapi CMS instance.
# If unset or empty, the site will automatically fall back to loading data from local public/data/*.json files.
VITE_STRAPI_API_URL=http://localhost:1337

# Optional API Token for authenticated requests (if you use read-restricted Strapi permissions)
VITE_STRAPI_TOKEN=
